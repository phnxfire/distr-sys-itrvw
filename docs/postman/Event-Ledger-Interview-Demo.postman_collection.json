{
  "info": {
    "_postman_id": "b9fb88ce-5dbd-4c23-84b4-event-ledger-interview",
    "name": "Event Ledger Interview Demo",
    "description": "Interview-focused Postman collection that demonstrates the take-home requirements: validation, idempotency, out-of-order tolerance, balances, service separation, contracts, tracing, metrics, and graceful degradation scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "accountServiceUrl",
      "value": "http://127.0.0.1:8001"
    },
    {
      "key": "runFailureDemo",
      "value": "false"
    },
    {
      "key": "runId",
      "value": ""
    },
    {
      "key": "accountId",
      "value": ""
    },
    {
      "key": "traceAccountId",
      "value": ""
    },
    {
      "key": "internalAccountId",
      "value": ""
    },
    {
      "key": "creditEventId",
      "value": ""
    },
    {
      "key": "debitEventId",
      "value": ""
    },
    {
      "key": "traceEventId",
      "value": ""
    },
    {
      "key": "internalEventId",
      "value": ""
    },
    {
      "key": "traceId",
      "value": "4bf92f3577b34da6a3ce929d0e0e4736"
    },
