              "raw": "{\n  \"eventId\": \"evt-eur-{{runId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 10.0,\n  \"currency\": \"EUR\",\n  \"eventTimestamp\": \"2026-05-15T17:02:11Z\",\n  \"metadata\": {\n    \"source\": \"postman-interview\"\n  }\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "19 Balance Remains Unchanged After Currency Rejection",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Rejected currency conflict did not mutate balance', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().balance).to.eql(124.5);",
                  "  pm.expect(pm.response.json().currency).to.eql('USD');",
