              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts/{{accountId}}/balance"
          }
        }
      ]
    },
    {
      "name": "03 Tracing, Logs, and Observability",
      "description": "Demonstrates trace headers, trace-compatible behavior, structured-log correlation, and metrics. Watch the running Gateway and Account Service terminals while sending these requests to see JSON logs with trace IDs.",
      "item": [
        {
          "name": "20 X-Trace-Id Correlation Demo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway echoes caller supplied X-Trace-Id', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(pm.response.headers.get('X-Trace-Id')).to.eql(pm.collectionVariables.get('xTraceId'));",
                  "});",
                  "pm.test('Use the X-Trace-Id to find Gateway and Account Service JSON logs', function () {",
                  "  pm.expect(true).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Trace-Id",
                "value": "{{xTraceId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{traceEventId}}\",\n  \"accountId\": \"{{traceAccountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 1.0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T18:02:11Z\",\n  \"metadata\": {\n    \"source\": \"postman-trace-demo\"\n  }\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "21 W3C traceparent Echo Demo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway accepts W3C traceparent and echoes trace context', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.headers.get('X-Trace-Id')).to.eql(pm.collectionVariables.get('traceId'));",
                  "  pm.expect(pm.response.headers.get('traceparent')).to.include(pm.collectionVariables.get('traceId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
