            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "18 Currency Conflict Returns 409",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Second currency for an existing account is rejected', function () {",
                  "  pm.response.to.have.status(409);",
                  "  pm.expect(pm.response.json().detail).to.include('already uses currency USD');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
