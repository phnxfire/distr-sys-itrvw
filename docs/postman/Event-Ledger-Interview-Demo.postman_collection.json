    {
      "name": "05 Manual Graceful Degradation and Circuit Breaker Demo",
      "description": "Manual interview demo. Run the earlier folders first. Then stop only Account Service, set collection variable runFailureDemo=true, and run this folder. Gateway-owned event reads should still work. New writes and balance proxy reads should return 503. Repeated write failures should open the circuit breaker. Restart Account Service after the demo.",
      "item": [
        {
          "name": "28 Gateway Local Event Read Still Works During Account Outage",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway-owned event read works without Account Service', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/{{creditEventId}}"
          }
        },
        {
          "name": "29 POST During Account Outage Returns 503",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.collectionVariables.get('runFailureDemo') === 'true') {",
                  "  pm.test('Gateway rejects new event when Account Service is unavailable', function () {",
                  "    pm.response.to.have.status(503);",
                  "    pm.expect(pm.response.json().detail).to.include('not accepted');",
                  "  });",
                  "} else {",
                  "  pm.test('Skipped outage assertion because runFailureDemo is false', function () { pm.expect(true).to.eql(true); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
