    }
  ],
  "item": [
    {
      "name": "00 Startup, Health, and Contracts",
      "description": "Demonstrates independently runnable services, health checks, separate API contracts, and the public Gateway/internal Account Service split.",
      "item": [
        {
          "name": "00 Initialize Fresh Demo Variables and Gateway Health",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = Date.now().toString();",
                  "pm.collectionVariables.set('runId', runId);",
                  "pm.collectionVariables.set('accountId', 'acct-interview-' + runId);",
                  "pm.collectionVariables.set('traceAccountId', 'acct-trace-' + runId);",
                  "pm.collectionVariables.set('internalAccountId', 'acct-internal-' + runId);",
                  "pm.collectionVariables.set('creditEventId', 'evt-credit-' + runId);",
                  "pm.collectionVariables.set('debitEventId', 'evt-debit-' + runId);",
                  "pm.collectionVariables.set('traceEventId', 'evt-trace-' + runId);",
                  "pm.collectionVariables.set('internalEventId', 'evt-internal-' + runId);",
                  "pm.collectionVariables.set('runFailureDemo', 'false');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway is independently running and healthy', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.service).to.eql('event-gateway');",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.database).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "01 Account Service Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account Service is independently running and healthy', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.service).to.eql('account-service');",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.database).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{accountServiceUrl}}/health"
          }
        },
        {
          "name": "02 Gateway OpenAPI Contract",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway exposes expected public API contract', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const paths = pm.response.json().paths;",
                  "  pm.expect(paths).to.have.property('/events');",
                  "  pm.expect(paths).to.have.property('/events/{event_id}');",
                  "  pm.expect(paths).to.have.property('/accounts/{account_id}/balance');",
                  "  pm.expect(paths).to.have.property('/health');",
                  "  pm.expect(paths).to.have.property('/metrics');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/openapi.json"
          }
        },
        {
          "name": "03 Account Service OpenAPI Contract",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account Service exposes expected internal API contract', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const paths = pm.response.json().paths;",
                  "  pm.expect(paths).to.have.property('/accounts/{account_id}/transactions');",
                  "  pm.expect(paths).to.have.property('/accounts/{account_id}/balance');",
                  "  pm.expect(paths).to.have.property('/accounts/{account_id}');",
                  "  pm.expect(paths).to.have.property('/health');",
                  "  pm.expect(paths).to.have.property('/metrics');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{accountServiceUrl}}/openapi.json"
          }
        }
      ]
    },
    {
      "name": "01 Core Ledger Requirements",
      "description": "Demonstrates event acceptance, persistence, duplicate replay, conflicting duplicate rejection, out-of-order ordering, synchronous Gateway to Account Service calls, balance computation, and metrics.",
      "item": [
        {
          "name": "04 Submit Credit Event Through Gateway",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway accepts and stores a new event', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "  pm.expect(body.accountId).to.eql(pm.collectionVariables.get('accountId'));",
                  "  pm.expect(body.status).to.eql('APPLIED');",
                  "});",
                  "pm.test('W3C traceparent trace ID is echoed as X-Trace-Id', function () {",
                  "  pm.expect(pm.response.headers.get('X-Trace-Id')).to.eql(pm.collectionVariables.get('traceId'));",
                  "  pm.expect(pm.response.headers.get('traceparent')).to.include(pm.collectionVariables.get('traceId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "traceparent",
                "value": "00-{{traceId}}-00f067aa0ba902b7-01"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{creditEventId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 150.0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T14:02:11Z\",\n  \"metadata\": {\n    \"source\": \"postman-interview\",\n    \"batchId\": \"B-INTERVIEW\"\n  }\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "05 Retrieve Stored Event By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway can read its locally stored event record', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "  pm.expect(body.status).to.eql('APPLIED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/{{creditEventId}}"
          }
        },
        {
          "name": "06 Exact Duplicate Replay Returns 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Duplicate event is replayed idempotently', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{creditEventId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 150.0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T14:02:11Z\",\n  \"metadata\": {\n    \"source\": \"postman-interview\",\n    \"batchId\": \"B-INTERVIEW\"\n  }\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "07 Conflicting Event ID Reuse Returns 409",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Same eventId with different business facts is rejected', function () {",
                  "  pm.response.to.have.status(409);",
                  "  pm.expect(pm.response.json().detail).to.include('eventId already exists');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{creditEventId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 999.0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T14:02:11Z\",\n  \"metadata\": {\n    \"source\": \"postman-interview\",\n    \"batchId\": \"B-INTERVIEW\"\n  }\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "08 Submit Earlier Debit Event Out Of Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Earlier debit event is accepted after later credit arrived first', function () {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(pm.response.json().eventId).to.eql(pm.collectionVariables.get('debitEventId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{debitEventId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"DEBIT\",\n  \"amount\": 25.5,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T13:02:11Z\",\n  \"metadata\": {\n    \"source\": \"postman-interview\",\n    \"batchId\": \"B-INTERVIEW\"\n  }\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "09 List Events In Chronological Business Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Event history is ordered by eventTimestamp, not arrival order', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const events = pm.response.json();",
                  "  pm.expect(events).to.have.length(2);",
                  "  pm.expect(events[0].eventId).to.eql(pm.collectionVariables.get('debitEventId'));",
                  "  pm.expect(events[1].eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events?account={{accountId}}"
          }
        },
        {
          "name": "10 Balance Is CREDIT Minus DEBIT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Balance is 150.0 - 25.5 = 124.5', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accountId).to.eql(pm.collectionVariables.get('accountId'));",
                  "  pm.expect(body.balance).to.eql(124.5);",
                  "  pm.expect(body.currency).to.eql('USD');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts/{{accountId}}/balance"
          }
        },
        {
          "name": "11 Account Details Include Ordered Transactions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account details include balance and chronological history', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.balance).to.eql(124.5);",
                  "  pm.expect(body.recentTransactions[0].eventId).to.eql(pm.collectionVariables.get('debitEventId'));",
                  "  pm.expect(body.recentTransactions[1].eventId).to.eql(pm.collectionVariables.get('creditEventId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/accounts/{{accountId}}"
          }
        },
        {
          "name": "12 Gateway Metrics Show Business Outcomes",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Gateway metrics include request and ledger-domain counters', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.requests).to.have.property('POST /events');",
                  "  pm.expect(body.latency).to.have.property('POST /events');",
                  "  pm.expect(body.domainEvents['gateway.events.accepted']).to.be.at.least(2);",
                  "  pm.expect(body.domainEvents['gateway.events.duplicate_replay']).to.be.at.least(1);",
                  "  pm.expect(body.domainEvents['gateway.events.idempotency_conflict']).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/metrics"
          }
        },
        {
          "name": "13 Account Service Metrics Show Applied Transactions",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account metrics include applied transaction counter', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const counters = pm.response.json().domainEvents;",
                  "  pm.expect(counters['account.transactions.applied']).to.be.at.least(2);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{accountServiceUrl}}/metrics"
          }
        }
      ]
    },
    {
      "name": "02 Validation and Business Rejections",
      "description": "Demonstrates Pydantic validation and business-rule rejection paths.",
      "item": [
        {
          "name": "14 Invalid Event Type Returns 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unknown event type is rejected by validation', function () {",
                  "  pm.response.to.have.status(422);",
                  "  pm.expect(pm.response.json()).to.have.property('detail');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-invalid-type-{{runId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"TRANSFER\",\n  \"amount\": 10.0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T16:02:11Z\",\n  \"metadata\": {}\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "15 Zero Amount Returns 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Zero amount is rejected by validation', function () {",
                  "  pm.response.to.have.status(422);",
                  "  pm.expect(pm.response.json()).to.have.property('detail');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-zero-{{runId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T16:02:11Z\",\n  \"metadata\": {}\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "16 Missing Required Field Returns 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Missing accountId is rejected by validation', function () {",
                  "  pm.response.to.have.status(422);",
                  "  pm.expect(pm.response.json()).to.have.property('detail');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"evt-missing-account-{{runId}}\",\n  \"type\": \"CREDIT\",\n  \"amount\": 10.0,\n  \"currency\": \"USD\",\n  \"eventTimestamp\": \"2026-05-15T16:02:11Z\",\n  \"metadata\": {}\n}"
            },
            "url": "{{baseUrl}}/events"
          }
        },
        {
          "name": "17 Timezone-Naive Timestamp Returns 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Timezone-naive timestamp is rejected', function () {",
                  "  pm.response.to.have.status(422);",
